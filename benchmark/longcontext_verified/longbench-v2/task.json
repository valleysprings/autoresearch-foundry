{
  "id": "longbench-v2",
  "title": "LongBench v2",
  "description": "Return the final answer for each LongBench v2 long-context multiple-choice question, using a prepared local manifest and per-item cached context files.",
  "benchmark_tier": "comparable",
  "track": "longcontext_verified",
  "dataset_id": "longbench_v2",
  "dataset_size": 503,
  "local_dataset_only": true,
  "item_manifest": "data/questions.json",
  "split": "train",
  "runtime_split_selector": {
    "label": "Split",
    "default_value": "all",
    "options": [
      {
        "value": "all",
        "title": "All Domains",
        "description": "Evaluate across the full released LongBench v2 domain mix.",
        "item_count": 503
      },
      {
        "value": "single-document-qa",
        "title": "Single-Document QA",
        "item_count": 175,
        "match_tags_any": ["domain:single-document-qa"]
      },
      {
        "value": "multi-document-qa",
        "title": "Multi-Document QA",
        "item_count": 125,
        "match_tags_any": ["domain:multi-document-qa"]
      },
      {
        "value": "long-in-context-learning",
        "title": "Long In-context Learning",
        "item_count": 81,
        "match_tags_any": ["domain:long-in-context-learning"]
      },
      {
        "value": "code-repository-understanding",
        "title": "Code Repository Understanding",
        "item_count": 50,
        "match_tags_any": ["domain:code-repository-understanding"]
      },
      {
        "value": "long-dialogue-history-understanding",
        "title": "Long-dialogue History Understanding",
        "item_count": 39,
        "match_tags_any": ["domain:long-dialogue-history-understanding"]
      },
      {
        "value": "long-structured-data-understanding",
        "title": "Long Structured Data Understanding",
        "item_count": 33,
        "match_tags_any": ["domain:long-structured-data-understanding"]
      }
    ]
  },
  "allow_browsing": false,
  "answer_metric": "accuracy",
  "family": "qa",
  "task_mode": "answer",
  "interaction_mode": "single_turn",
  "task_signature": [
    "editable-file-optimization",
    "single-turn",
    "dataset-task",
    "long-context-reasoning",
    "multiple-choice-qa"
  ],
  "editable_file": "editable.py",
  "verifier": "verifier.py",
  "entry_symbol": "solve",
  "generation_budget": 3,
  "candidate_budget": 2,
  "branching_factor": 3,
  "item_workers": 1,
  "epsilon": 0.02,
  "baseline_summary": "A placeholder long-context solver template that returns the first available answer choice.",
  "objective_spec": {
    "display_name": "Accuracy",
    "direction": "max",
    "unit": "ratio",
    "summary_template": "Higher accuracy is better across independently evolved LongBench v2 question runs.",
    "formula": "accuracy = solved_questions / total_questions"
  },
  "prompt_context": "Edit editable.py only. The active item is a single long-context multiple-choice reasoning question. The full context may be large and is still available at runtime in question['context']; write a local heuristic over question['prompt'], question['context'], and question['choices'] without any network access.",
  "prompt_context_max_chars": 4000,
  "result_context_max_chars": 1200,
  "function_name": "solve"
}
