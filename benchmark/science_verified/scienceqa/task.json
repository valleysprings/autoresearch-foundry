{
  "id": "scienceqa",
  "title": "ScienceQA Text Bio/Chem/Phys",
  "description": "Return the final answer for each text-only ScienceQA validation question from biology, chemistry, and physics.",
  "benchmark_tier": "comparable",
  "track": "science_verified",
  "dataset_id": "scienceqa",
  "dataset_size": 768,
  "local_dataset_only": true,
  "item_manifest": "data/questions.json",
  "split": "validation:natural-science:text-only:biology-chemistry-physics",
  "runtime_split_selector": {
    "label": "Split",
    "default_value": "all",
    "options": [
      {
        "value": "all",
        "title": "All Topics",
        "description": "Evaluate across biology, chemistry, and physics together.",
        "item_count": 768
      },
      {
        "value": "biology",
        "title": "Biology",
        "item_count": 406,
        "match_tags_any": ["topic:biology"]
      },
      {
        "value": "chemistry",
        "title": "Chemistry",
        "item_count": 136,
        "match_tags_any": ["topic:chemistry"]
      },
      {
        "value": "physics",
        "title": "Physics",
        "item_count": 226,
        "match_tags_any": ["topic:physics"]
      }
    ]
  },
  "allow_browsing": false,
  "answer_metric": "accuracy",
  "family": "science",
  "task_mode": "answer",
  "interaction_mode": "single_turn",
  "task_signature": [
    "single-file-optimization",
    "single-turn",
    "dataset-task",
    "science-question-solving",
    "reasoning"
  ],
  "editable_file": "editable.py",
  "verifier": "verifier.py",
  "entry_symbol": "solve",
  "generation_budget": 4,
  "candidate_budget": 3,
  "branching_factor": 4,
  "epsilon": 0.02,
  "baseline_summary": "A placeholder dataset-level solver template that returns the first available answer choice.",
  "objective_spec": {
    "display_name": "Accuracy",
    "direction": "max",
    "unit": "ratio",
    "summary_template": "Higher accuracy is better across independently evolved ScienceQA question runs.",
    "formula": "accuracy = solved_questions / total_questions"
  },
  "prompt_context": "Edit editable.py only. The entry symbol solve(question: dict) must return the best answer string for the current text-only science question.",
  "function_name": "solve"
}
